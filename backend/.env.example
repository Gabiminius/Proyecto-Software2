# Base de datos PostgreSQL en Neon
# Reemplaza USER, PASSWORD, HOST y DBNAME con tus credenciales
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require

# Configuración de la aplicación
PROJECT_NAME=Sistema de Incidentes Escolares API
API_V1_STR=/api/v1

# CORS - Orígenes del frontend permitidos
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_FALLBACK=http://localhost:5174

# Timeouts para la conexión a BD
DB_CONNECT_TIMEOUT=8
DB_COMMAND_TIMEOUT=10
